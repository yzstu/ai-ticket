# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:480b-cloud

# AKShare Configuration (Primary Data Source)
AKSHARE_TIMEOUT=30
AKSHARE_MAX_RETRIES=3

# YFinance Configuration (Backup Data Source)
YFINANCE_TIMEOUT=30
YFINANCE_MAX_RETRIES=3

# Analysis Configuration
# Maximum stocks to analyze (0 = analyze all stocks)
MAX_STOCKS_TO_ANALYZE=0

# Stock Analysis Configuration
TEMPERATURE=0.3

# Tushare Token (optional for real data)
# TUSHARE_TOKEN=your_tushare_token_here

# Logging
LOG_LEVEL=INFO